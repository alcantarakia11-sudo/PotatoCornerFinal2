## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options directory
.vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/

# Visual Studio cache files
*.cache
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Web workbench (sass)
.sass-cache/

# Backup folder for Package Reference Convert tool in Visual Studio 2017
MigrationBackup/

# Backup files
Backups/
*.bak

# Uploads folder (contains user uploaded images)
Uploads/

# Connection strings (if you want to keep them private)
# Uncomment the line below if you don't want to share connection strings
# Web.config
