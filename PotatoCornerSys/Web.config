<?xml version="1.0" encoding="utf-8"?>
<!-- Application restart trigger -->
<configuration>
	<connectionStrings>
		<add name="PotatoCornerDB"
			 connectionString="Data Source=DESKTOP-KTCD3QB\SQLEXPRESS;Initial Catalog=PotatoCorner_DB;Integrated Security=True;TrustServerCertificate=True;"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>
	<system.web>
		<compilation debug="true" targetFramework="4.8" />
		<httpRuntime targetFramework="4.8" />
		<sessionState mode="InProc" timeout="60" />
	</system.web>
</configuration>

	
